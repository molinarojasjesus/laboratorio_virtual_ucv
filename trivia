<!DOCTYPE html>
<html lang="es-PE">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>🏆 El Laberinto de las Preguntas - Trivia Ciclo de Vida</title>
    <style>
        /* ===== VARIABLES Y RESET ===== */
        :root {
            --primary-gradient: linear-gradient(90deg, #1E3A8A, #3B82F6);
            --bg-gradient: linear-gradient(180deg, #BAE6FD 0%, #F0FDF4 60%, #DCFCE7 100%);
            --correct-color: #22C55E;
            --incorrect-color: #EF4444;
            --warning-color: #F59E0B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
            padding-top: 25px;
            touch-action: manipulation;
            overflow-x: hidden;
        }

        .app {
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(8px);
            border-radius: 40px 40px 30px 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            max-width: 900px;
            width: 100%;
            display: grid;
            grid-template-rows: auto 1fr auto;
            overflow: hidden;
            border: 4px solid #FFF;
        }

        /* ===== HEADER INSTITUCIONAL ===== */
        header {
            background: var(--primary-gradient);
            color: #FFF;
            padding: 15px 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .institution-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 8px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            padding-bottom: 10px;
        }

        .logo-ucv-container {
            width: 55px;
            height: 55px;
            background: white;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.15);
            padding: 4px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .logo-ucv-container img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .institution-text h2 {
            font-size: 1.1rem;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .institution-text p {
            font-size: 0.85rem;
            color: #BFDBFE;
            font-weight: 600;
            text-transform: uppercase;
        }

        .game-title-container {
            text-align: center;
            margin-top: 5px;
        }

        .game-title-container h1 {
            font-size: 1.5rem;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
        }

        /* ===== CONTENEDOR PRINCIPAL DEL JUEGO ===== */
        .main-content {
            display: grid;
            grid-template-columns: 1fr 280px;
            height: 480px;
            background: #FFF;
        }

        /* ÁREA DE PREGUNTAS */
        .game-board {
            padding: 25px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 15px;
            background: #FAFAFA;
        }

        .stats-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #F1F5F9;
            padding: 10px 20px;
            border-radius: 20px;
            border: 2px solid #E2E8F0;
        }

        .stat-item {
            font-weight: 800;
            font-size: 1.1rem;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .timer-badge {
            background: #FFF;
            padding: 4px 12px;
            border-radius: 12px;
            border: 2px solid #CBD5E1;
            transition: all 0.3s ease;
        }

        .timer-urgent {
            color: var(--incorrect-color);
            border-color: var(--incorrect-color);
            animation: pulseAlert 0.5s infinite alternate;
        }

        @keyframes pulseAlert {
            0% { transform: scale(1); }
            100% { transform: scale(1.05); }
        }

        .question-box {
            background: #FFF;
            border: 3px solid #E2E8F0;
            border-radius: 24px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 15px;
            position: relative;
        }

        .question-text {
            font-size: 1.2rem;
            color: #1E293B;
            font-weight: 700;
            line-height: 1.4;
        }

        .question-img {
            max-height: 110px;
            object-fit: contain;
            border-radius: 12px;
            display: none;
        }

        .fallback-text {
            font-size: 0.85rem;
            color: #94A3B8;
            font-style: italic;
        }

        .options-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
        }

        .option-btn {
            background: #FFF;
            border: 3px solid #CBD5E1;
            border-radius: 20px;
            padding: 14px 20px;
            font-size: 1.05rem;
            font-weight: 700;
            color: #475569;
            cursor: pointer;
            text-align: left;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 4px 0 #CBD5E1;
        }

        .option-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            border-color: #94A3B8;
            box-shadow: 0 6px 0 #94A3B8;
        }

        .option-btn:active:not(:disabled) {
            transform: translateY(4px);
            box-shadow: 0 0 0 transparent;
        }

        .option-btn.correct {
            background: #DCFCE7 !important;
            border-color: var(--correct-color) !important;
            color: #166534 !important;
            box-shadow: 0 4px 0 var(--correct-color) !important;
        }

        .option-btn.incorrect {
            background: #FEE2E2 !important;
            border-color: var(--incorrect-color) !important;
            color: #991B1B !important;
            box-shadow: 0 4px 0 var(--incorrect-color) !important;
        }

        /* PANEL VISUAL DE PROGRESO (LABERINTO/ÁRBOL) */
        .progress-side-panel {
            background: linear-gradient(180deg, #BAE6FD 0%, #E0F2FE 100%);
            border-left: 2px solid #E2E8F0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 20px 10px;
            position: relative;
        }

        .ladder-container {
            display: flex;
            flex-direction: column-reverse;
            gap: 12px;
            width: 100%;
            padding: 10px;
            flex-grow: 1;
            justify-content: center;
        }

        .ladder-step {
            background: rgba(255, 255, 255, 0.7);
            border: 2px dashed #94A3B8;
            border-radius: 12px;
            padding: 10px;
            text-align: center;
            font-weight: 700;
            font-size: 0.9rem;
            color: #64748B;
            transition: all 0.4s ease;
            position: relative;
        }

        .ladder-step.completed {
            background: #4CAF50;
            border-color: #FFF;
            color: #FFF;
            box-shadow: 0 4px 10px rgba(76,175,80,0.3);
            border-style: solid;
        }

        .ladder-step.current {
            background: #FFC107;
            border-color: #FFF;
            color: #000;
            border-style: solid;
            animation: pulseCurrentStep 1.5s infinite alternate;
        }

        @keyframes pulseCurrentStep {
            0% { transform: scale(1); }
            100% { transform: scale(1.03); box-shadow: 0 0 12px #FFC107; }
        }

        .goal-avatar-top {
            font-size: 2.2rem;
            margin-bottom: 5px;
            filter: drop-shadow(0 4px 5px rgba(0,0,0,0.15));
            transition: transform 0.3s ease;
        }

        .goal-avatar-top.saved {
            animation: winDance 0.6s infinite alternate;
        }

        @keyframes winDance {
            0% { transform: translateY(0) rotate(-10deg); }
            100% { transform: translateY(-10px) rotate(10deg); }
        }

        /* PANTALLAS DE FIN DE JUEGO (OVERLAYS) */
        .screen-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            z-index: 100;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 20px;
            padding: 30px;
            text-align: center;
            animation: fadeIn 0.3s ease forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; } to { opacity: 1; }
        }

        .screen-overlay h2 { font-size: 2.2rem; font-weight: 800; }
        .screen-overlay p { font-size: 1.2rem; color: #475569; max-width: 500px; font-weight: 500; }
        .screen-overlay .big-icon { font-size: 5rem; }

        .btn-restart {
            background: linear-gradient(90deg, #22C55E, #16A34A);
            color: white;
            border: none;
            padding: 15px 35px;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(34,197,94,0.4);
            transition: transform 0.2s;
        }
        .btn-restart:hover { transform: scale(1.05); }

        /* ===== DIÁLOGOS Y PIE DE PÁGINA ===== */
        .dialogue-section {
            background: #FFF7ED;
            border-top: 3px solid #FFEDD5;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            gap: 20px;
            position: relative;
        }

        .avatar-container {
            position: relative;
            width: 70px;
            height: 70px;
            flex-shrink: 0;
        }

        .avatar-bg {
            width: 100%;
            height: 100%;
            background: #FFD9A6;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 3rem;
            box-shadow: 0 4px 10px rgba(217,119,6,0.15);
            border: 3px solid #FFF;
        }

        .audio-wave {
            position: absolute;
            bottom: -2px;
            right: -2px;
            background: #4CAF50;
            color: white;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 0.75rem;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .dialogue-bubble {
            background: #FFF;
            border: 2px solid #FFEDD5;
            border-radius: 20px;
            padding: 12px 20px;
            flex-grow: 1;
            position: relative;
        }
        .dialogue-bubble::before {
            content: '';
            position: absolute;
            left: -12px;
            top: 50%;
            transform: translateY(-50%) rotate(45deg);
            width: 16px;
            height: 16px;
            background: #FFF;
            border-left: 2px solid #FFEDD5;
            border-bottom: 2px solid #FFEDD5;
        }

        .dialogue-text {
            font-size: 1rem;
            color: #7C2D12;
            font-weight: 600;
            line-height: 1.4;
        }

        /* RESPONSIVIDAD GENERAL */
        @media (max-width: 800px) {
            .main-content {
                grid-template-columns: 1fr;
                grid-template-rows: auto auto;
                height: auto;
            }
            .progress-side-panel {
                border-left: none;
                border-top: 2px solid #E2E8F0;
                flex-direction: row;
                padding: 15px;
            }
            .ladder-container {
                flex-direction: row;
                justify-content: space-around;
            }
            .ladder-step { padding: 6px 12px; font-size: 0.8rem; }
            .goal-avatar-top { order: 2; margin-bottom: 0; }
        }
    </style>
</head>
<body>

<div class="app" style="position: relative;">
    
    <!-- PANTALLAS FINALIZADORAS (OVERLAYS) -->
    <div class="screen-overlay" id="victoryScreen">
        <div class="big-icon">🎉🏆👩🏽‍🏫</div>
        <h2 style="color: var(--correct-color);">¡Excelente Trabajo!</h2>
        <p id="victoryMsg">¡Has respondido todas las preguntas correctamente y lograste alcanzar a la Profesora Jacinta en la cima del laberinto biológico!</p>
        <button class="btn-restart" onclick="resetGame()">Jugar de Nuevo</button>
    </div>

    <div class="screen-overlay" id="gameoverScreen">
        <div class="big-icon">😢🥀</div>
        <h2 style="color: var(--incorrect-color);">Sigue Intentándolo</h2>
        <p>Te has quedado sin vidas, pero la investigación es cuestión de perseverancia. ¡Repasa el ciclo y vuelve a intentarlo!</p>
        <button class="btn-restart" onclick="resetGame()" style="background: linear-gradient(90deg, #3B82F6, #1D4ED8); box-shadow: 0 5px 15px rgba(59,130,246,0.4);">Reintentar Desafío</button>
    </div>

    <!-- HEADER INSTITUCIONAL -->
    <header>
        <div class="institution-header">
            <div class="logo-ucv-container">
                <img src="logo_ucv.png" alt="Logo UCV" id="logoUcv" onerror="this.style.display='none';">
            </div>
            <div class="institution-text">
                <h2>UNIVERSIDAD CÉSAR VALLEJO</h2>
                <p>Escuela de Educación Primaria</p>
            </div>
        </div>
        <div class="game-title-container">
            <h1>🏆 El Laberinto de las Preguntas</h1>
        </div>
    </header>

    <!-- ÁREA CENTRAL DEL JUEGO -->
    <div class="main-content">
        <section class="game-board">
            <div class="stats-bar">
                <div class="stat-item" id="livesContainer">Vidas: ❤️❤️❤️</div>
                <div class="stat-item">Puntos: <span id="scoreText" style="color: #3B82F6;">0</span></div>
                <div class="stat-item">Tiempo: <span id="timerText" class="timer-badge">15s</span></div>
            </div>

            <div class="question-box" id="questionBox">
                <p class="question-text" id="questionText">Cargando desafío...</p>
                <!-- Control de resiliencia ante errores de imágenes -->
                <img src="" alt="Fase Visual" class="question-img" id="questionImg" onerror="handleImageError(this)">
                <div id="imageFallback" class="fallback-text" style="display: none;">🔬 Análisis de Fase Estructurada</div>
            </div>

            <div class="options-grid" id="optionsGrid">
                <button class="option-btn">Opción A</button>
                <button class="option-btn">Opción B</button>
                <button class="option-btn">Opción C</button>
            </div>
        </section>

        <!-- PANEL LATERAL DE PROGRESO -->
        <aside class="progress-side-panel">
            <div class="goal-avatar-top" id="topAvatar">👩🏽‍🏫</div>
            <div class="ladder-container" id="ladderContainer">
                <div class="ladder-step">Meta</div>
                <div class="ladder-step">Paso 4</div>
                <div class="ladder-step">Paso 3</div>
                <div class="ladder-step">Paso 2</div>
                <div class="ladder-step">Paso 1</div>
            </div>
        </aside>
    </div>

    <!-- AREA DE CONTROL E INSTRUCCIONES INFERIOR -->
    <footer class="dialogue-section">
        <div class="avatar-container">
            <div class="avatar-bg">👩🏽‍🏫</div>
            <div class="audio-wave" id="audioBtn" title="Escuchar la explicación">🔊</div>
        </div>
        <div class="dialogue-bubble">
            <p class="dialogue-text" id="dialogueText">¡Hola! Demuestra tus conocimientos científicos. Responde correctamente antes que el tiempo termine para escalar el laberinto vegetal.</p>
        </div>
    </footer>
</div>

<script>
    // BANCO DE PREGUNTAS SOBRE EL CICLO DE VIDA (MÍNIMO 5)
    const QUESTION_BANK = [
        {
            q: "¿Cuál es la primera etapa del ciclo de vida de una planta donde el embrión despierta?",
            options: ["La Floración", "La Germinación", "La Polinización"],
            correct: 1,
            img: "trivia_0.png"
        },
        {
            q: "¿Qué elemento es indispensable absorber para que la cáscara de la semilla se ablande?",
            options: ["Luz Artificial", "Oxígeno Seco", "Agua / Humedad"],
            correct: 2,
            img: "trivia_1.png"
        },
        {
            q: "¿Cómo se llama el proceso donde las hojas verdes absorben luz solar para fabricar su energía?",
            options: ["Fotosíntesis", "Germinación", "Dispersión"],
            correct: 0,
            img: "trivia_2.png"
        },
        {
            q: "¿Cuál es la función principal de las flores de colores vistosos en el girasol o maíz?",
            options: ["Evitar que los insectos se acerquen", "Atraer polinizadores para producir frutos y semillas", "Dar sombra a las raíces inferiores"],
            correct: 1,
            img: "trivia_3.png"
        },
        {
            q: "Cuando la planta completa su ciclo, se marchita y muere, ¿qué nos deja para reiniciar el ciclo?",
            options: ["Nuevas Semillas", "Agua acumulada", "Hojas marchitas fijas"],
            correct: 0,
            img: "trivia_4.png"
        },
        {
            q: "¿Hacia qué dirección crece siempre la raíz principal de una plántula al brotar?",
            options: ["Hacia los lados buscando viento", "Hacia arriba buscando luz de luna", "Hacia abajo buscando gravedad y minerales"],
            correct: 2,
            img: "trivia_5.png"
        }
    ];

    // ESTADO DEL JUEGO
    let state = {
        questions: [],
        currentIndex: 0,
        lives: 3,
        score: 0,
        timeLeft: 15,
        timerInterval: null,
        buttonsDisabled: false
    };

    // ACCESIBILIDAD DE AUDIO NATIVA (Voice Synthesis)
    function speak(text) {
        if (!window.speechSynthesis) return;
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'es-PE'; 
        window.speechSynthesis.speak(utterance);
    }

    function setDialogue(text) {
        document.getElementById('dialogueText').textContent = text;
        speak(text);
    }

    document.getElementById('audioBtn').addEventListener('click', () => {
        speak(document.getElementById('dialogueText').textContent);
    });

    // SISTEMA DE RESILIENCIA ANTE IMÁGENES ROTAS
    function handleImageError(imgElement) {
        imgElement.style.display = 'none';
        document.getElementById('imageFallback').style.display = 'block';
    }

    // INICIALIZACIÓN Y CONFIGURACIÓN DEL JUEGO
    function initGame() {
        // Mezclar banco de preguntas y seleccionar 5 al azar
        state.questions = [...QUESTION_BANK].sort(() => Math.random() - 0.5).slice(0, 5);
        state.currentIndex = 0;
        state.lives = 3;
        state.score = 0;
        state.buttonsDisabled = false;
        
        buildLadderUI();
        loadQuestion();
    }

    function buildLadderUI() {
        const container = document.getElementById('ladderContainer');
        container.innerHTML = '';
        
        // Crear dinámicamente los peldaños según el número de preguntas reales
        for (let i = 0; i < state.questions.length; i++) {
            const step = document.createElement('div');
            step.className = 'ladder-step';
            step.id = `step_${i}`;
            step.textContent = `Paso ${i + 1}`;
            container.appendChild(step);
        }
        
        const goalStep = document.createElement('div');
        goalStep.className = 'ladder-step';
        goalStep.id = `step_meta`;
        goalStep.style.fontWeight = '900';
        goalStep.textContent = "🏆 META";
        container.appendChild(goalStep);
    }

    function updateLadderVisuals() {
        for (let i = 0; i < state.questions.length; i++) {
            const step = document.getElementById(`step_${i}`);
            if (step) {
                step.classList.remove('completed', 'current');
                if (i < state.currentIndex) step.classList.add('completed');
                else if (i === state.currentIndex) step.classList.add('current');
            }
        }
        const goal = document.getElementById('step_meta');
        if (goal) {
            goal.classList.remove('current');
            if (state.currentIndex === state.questions.length) goal.classList.add('current');
        }
    }

    function loadQuestion() {
        if (state.currentIndex >= state.questions.length) {
            endGame(true);
            return;
        }

        state.buttonsDisabled = false;
        updateLadderVisuals();
        clearInterval(state.timerInterval);
        
        // Renderizar contadores básicos
        document.getElementById('scoreText').textContent = state.score;
        renderLives();

        const currentQ = state.questions[state.currentIndex];
        
        // Cargar texto e imagen de la pregunta
        document.getElementById('questionText').textContent = currentQ.q;
        const img = document.getElementById('questionImg');
        const fallback = document.getElementById('imageFallback');
        
        fallback.style.display = 'none';
        img.src = currentQ.img;
        img.style.display = 'block';

        // Renderizar opciones mezcladas
        const optionsGrid = document.getElementById('optionsGrid');
        optionsGrid.innerHTML = '';

        currentQ.options.forEach((opt, idx) => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.textContent = opt;
            btn.addEventListener('click', () => handleAnswer(idx, btn));
            optionsGrid.appendChild(btn);
        });

        // Configuración e inicio de cuenta regresiva
        state.timeLeft = 15;
        const timerText = document.getElementById('timerText');
        timerText.textContent = `${state.timeLeft}s`;
        timerText.classList.remove('timer-urgent');

        state.timerInterval = setInterval(() => {
            state.timeLeft--;
            timerText.textContent = `${state.timeLeft}s`;
            
            if (state.timeLeft <= 5) {
                timerText.classList.add('timer-urgent');
            }
            if (state.timeLeft <= 0) {
                clearInterval(state.timerInterval);
                handleTimeout();
            }
        }, 1000);
    }

    function renderLives() {
        const container = document.getElementById('livesContainer');
        container.textContent = 'Vidas: ' + '❤️'.repeat(state.lives) + '🖤'.repeat(3 - state.lives);
    }

    function handleAnswer(selectedIndex, selectedButton) {
        if (state.buttonsDisabled) return;
        state.buttonsDisabled = true;
        clearInterval(state.timerInterval);

        const currentQ = state.questions[state.currentIndex];
        const allButtons = document.querySelectorAll('.option-btn');

        if (selectedIndex === currentQ.correct) {
            selectedButton.classList.add('correct');
            state.score += 20;
            state.currentIndex++;
            setDialogue("¡Espectacular! Has analizado la etapa biológica correctamente. ¡Subes un peldaño!");
            
            setTimeout(() => {
                loadQuestion();
            }, 2000);
        } else {
            selectedButton.classList.add('incorrect');
            allButtons[currentQ.correct].classList.add('correct');
            state.lives--;
            setDialogue("Oh, respuesta incorrecta. Recuerda los requerimientos del ciclo vital.");
            
            setTimeout(() => {
                if (state.lives <= 0) endGame(false);
                else loadQuestion();
            }, 2500);
        }
    }

    function handleTimeout() {
        if (state.buttonsDisabled) return;
        state.buttonsDisabled = true;
        
        state.lives--;
        setDialogue("¡Se agotó el tiempo de análisis científico! Perdiste una vida.");
        
        const currentQ = state.questions[state.currentIndex];
        const allButtons = document.querySelectorAll('.option-btn');
        if (allButtons[currentQ.correct]) {
            allButtons[currentQ.correct].classList.add('correct');
        }

        setTimeout(() => {
            if (state.lives <= 0) endGame(false);
            else loadQuestion();
        }, 2500);
    }

    function endGame(isVictory) {
        clearInterval(state.timerInterval);
        if (isVictory) {
            document.getElementById('topAvatar').classList.add('saved');
            document.getElementById('victoryMsg').textContent = `¡Felicidades investigador! Lograste una puntuación de ${state.score} puntos y escalaste todo el ecosistema con éxito.`;
            document.getElementById('victoryScreen').style.display = 'flex';
            speak("¡Excelente Trabajo! Has respondido todas las preguntas correctamente.");
        } else {
            document.getElementById('gameoverScreen').style.display = 'flex';
            speak("Sigue Intentándolo. Te has quedado sin vidas, pero puedes volver a iniciar.");
        }
    }

    function resetGame() {
        document.getElementById('victoryScreen').style.display = 'none';
        document.getElementById('gameoverScreen').style.display = 'none';
        document.getElementById('topAvatar').classList.remove('saved');
        setDialogue("¡Laboratorio de preguntas reiniciado! Lee con atención.");
        initGame();
    }

    // Ejecución inicial al cargar la ventana
    window.onload = initGame;
</script>
</body>
</html>
